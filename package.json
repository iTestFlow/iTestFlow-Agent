{
  "name": "itestflow-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first test intelligence command center for Azure DevOps testing workflows.",
  "scripts": {
    "dev": "node scripts/next-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:down": "node-pg-migrate down",
    "db:migrate:create": "node-pg-migrate create --migration-file-language js",
    "db:reset-dev": "node-pg-migrate down 999999 && node-pg-migrate up",
    "worker": "node --conditions=react-server --import tsx src/worker/main.ts",
    "worker:dev": "node --env-file=.env --conditions=react-server --watch --import tsx src/worker/main.ts",
    "org:enable": "node --env-file=.env --conditions=react-server --import tsx src/scripts/manage-org.ts enable",
    "org:disable": "node --env-file=.env --conditions=react-server --import tsx src/scripts/manage-org.ts disable"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.1",
    "tsx": "^4.19.2",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
