# Database
DATABASE_URL=postgresql://itestflow:itestflow@localhost:5432/itestflow
DATABASE_POOL_MAX=10

# App mode
# hosted: multi-user workspace mode. User Azure/LLM credentials are stored encrypted in the database.
# single-user: legacy local development mode where the bootstrap credentials below may be used.
APP_MODE=hosted

# Auth and bootstrap
SESSION_SECRET=
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_AZURE_ORG=

# Credential encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=
CREDENTIAL_STALE_DAYS=60

# Background worker
# Run with `npm run worker` in production, or `npm run worker:dev` locally.
WORKER_SCHEDULER=
WORKER_SCHEDULER_TICK_MS=60000
WORKER_POLL_MS=2000
WORKER_HEARTBEAT_MS=30000
JOB_STALE_LOCK_MS=300000

# Rate limiting
# Leave empty for in-memory limits. Use "postgres" when multiple web replicas need shared limits.
RATE_LIMIT_BACKEND=

# Deployment defaults
# Workspace settings override these where applicable.
PROJECT_CONTEXT_TOP_K=8
LLM_MAX_OUTPUT_TOKEN_CAP=32000
LLM_RETRY_ATTEMPTS=1

# Single-user/dev Azure and LLM credentials
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PAT=
DEFAULT_LLM_PROVIDER=
NEXT_PUBLIC_LLM_PROVIDER_LABEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
