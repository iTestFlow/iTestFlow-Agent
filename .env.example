# Database
DATABASE_URL=postgresql://itestflow:itestflow@localhost:5432/itestflow
DATABASE_POOL_MAX=10

# Auth and bootstrap
# SESSION_SECRET is optional/reserved (cookie HMAC hardening); sessions are stateful
# and do not require it today.
SESSION_SECRET=

# Bootstrap seeds the enabled Azure org(s) + owner(s) on startup. Pick the mode you need.
# In both, the owner email must match that org's Azure unique name/UPN so the seeded
# owner is recognized on first PAT login. Bootstrap is ADDITIVE — removing an org here
# does NOT remove it; disable one with:  npm run org:disable -- <orgUrlOrName>
# (re-enable with org:enable).
#
# Single-org setup — one org with one owner:
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_AZURE_ORG=
#
# Multi-org setup — several orgs, EACH with its own owner. Comma-separated
# "orgUrlOrName|ownerEmail" entries; when set, this takes precedence. An entry may omit
# "|email" to inherit BOOTSTRAP_OWNER_EMAIL above. Example:
#   BOOTSTRAP_AZURE_ORGS=https://dev.azure.com/org-a|admin@company.com, https://dev.azure.com/org-b|owner-b@company.com
BOOTSTRAP_AZURE_ORGS=

# Credential encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=
CREDENTIAL_STALE_DAYS=60

# Background worker
# Run with `npm run worker` in production, or `npm run worker:dev` locally.
WORKER_SCHEDULER=
WORKER_SCHEDULER_TICK_MS=60000
WORKER_POLL_MS=2000
WORKER_HEARTBEAT_MS=30000
JOB_STALE_LOCK_MS=300000

# Rate limiting
# Backend defaults to "postgres" when NODE_ENV=production (shared limit across web
# replicas) and "memory" otherwise. Set explicitly to "postgres" or "memory" to override.
RATE_LIMIT_BACKEND=
# Number of trusted reverse proxies / load balancers in front of the app. The client
# IP for login throttling is read this many hops from the right of X-Forwarded-For,
# so a client cannot dodge its bucket by prepending fake IPs. 0 = take the nearest
# proxy's reported IP (rightmost entry). Set to your real proxy depth.
RATE_LIMIT_TRUSTED_PROXY_HOPS=0

# Deployment defaults (workspace settings override these where applicable)
PROJECT_CONTEXT_TOP_K=8
LLM_MAX_OUTPUT_TOKEN_CAP=32000

# Semantic retrieval. On by default via the local zero-setup backend: workflow
# retrieval fuses semantic similarity with full-text and trigram rank (reciprocal
# rank fusion). Any embedding failure automatically degrades back to full-text/
# trigram-only retrieval. Set EMBEDDINGS_PROVIDER=off to disable entirely.
#   EMBEDDINGS_PROVIDER: off | local | ollama | openai | gemini
#     - local (default): zero setup — nomic-embed-text runs in-process via
#       transformers.js/ONNX; the quantized model (~70MB) auto-downloads on first
#       use into data/model-cache. No server, no API key, nothing to install.
#     - ollama: local Ollama server, no API key (default model nomic-embed-text;
#       install with `ollama pull nomic-embed-text`)
#     - openai: OpenAI cloud (needs EMBEDDINGS_API_KEY), or any OpenAI-compatible
#       local server (LM Studio, llama.cpp, vLLM) via EMBEDDINGS_BASE_URL — a local
#       base URL needs no key
#     - gemini: Google cloud, needs EMBEDDINGS_API_KEY
#   EMBEDDINGS_MODEL:       optional model override (per-provider default when empty)
#   EMBEDDINGS_BASE_URL:    optional endpoint override for server providers
#                           (ollama default http://127.0.0.1:11434)
#   EMBEDDINGS_API_KEY:     cloud providers only
#   EMBEDDINGS_LOCAL_DTYPE: local only — q8 (default, quantized ~70MB) | fp16 | fp32 | q4
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_LOCAL_DTYPE=

