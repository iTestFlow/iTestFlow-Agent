# ─────────────────────────────────────────────────────────────────────────────
# Database (required) — Phase 1a
# Local dev default matches docker-compose.yml. node-pg-migrate and the app both
# read DATABASE_URL. Put real values in `.env` (loaded by both Next.js and the
# migration CLI); never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://itestflow:itestflow@localhost:5432/itestflow

# ─────────────────────────────────────────────────────────────────────────────
# Application mode — Phase 1b
#   hosted       = multi-user; env credentials below are IGNORED (private creds
#                  resolved per user from the database).
#   single-user  = legacy local-first; the env credentials below are honored.
# ─────────────────────────────────────────────────────────────────────────────
APP_MODE=single-user

# Background worker (Phase 4). The worker process (`npm run worker`) owns scheduled
# Azure DevOps sync using the workspace sync credential. Each workspace sets its own
# cadence via a cron schedule (Settings → Workspace); the worker evaluates due
# schedules on a tick. A workspace with no schedule is never auto-synced.
#   WORKER_SCHEDULER         — set "false" to disable scheduling (default on).
#   WORKER_SCHEDULER_TICK_MS — schedule evaluation interval (default 60000 = 60s).
#   WORKER_POLL_MS           — idle poll interval (default 2000).
WORKER_SCHEDULER=
WORKER_SCHEDULER_TICK_MS=
WORKER_POLL_MS=

# Rate limiting for sensitive endpoints (login, credential save). Default "memory"
# limits per-process — fine for a single web replica. Set "postgres" when running
# MULTIPLE web replicas so the limit is shared/global (uses DATABASE_URL).
RATE_LIMIT_BACKEND=

# ─────────────────────────────────────────────────────────────────────────────
# Auth / bootstrap — Phase 1b (documented now, consumed in 1b)
# ─────────────────────────────────────────────────────────────────────────────
SESSION_SECRET=
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_AZURE_ORG=

# ─────────────────────────────────────────────────────────────────────────────
# Credential encryption — Phase 2 (documented now, consumed in 2)
# 32-byte key, base64-encoded. Stored OUTSIDE the database and the app data dir.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Single-user / dev credentials (honored only when APP_MODE=single-user)
# ─────────────────────────────────────────────────────────────────────────────
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PAT=
DEFAULT_LLM_PROVIDER=
NEXT_PUBLIC_LLM_PROVIDER_LABEL=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
LLM_MAX_OUTPUT_TOKEN_CAP=32000
LLM_RETRY_ATTEMPTS=1

# Retrieval breadth (top-K): how many related work items the AI pulls in as
# context. This is the DEPLOYMENT-WIDE DEFAULT. In hosted mode an owner/admin can
# override it per workspace in Settings → Workspace (DB value wins; this env is the
# fallback; 8 if unset). Clamped to 1..25.
PROJECT_CONTEXT_TOP_K=8
